{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bagart/telegram-bot-lib",
    "description": "Telegram Bot core library",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "telegram",
        "tg-bot",
        "tg-api",
        "telegram-bot",
        "telegram-api",
        "bot-platform",
        "ASK",
        "async",
        "pipeline",
        "client",
        "execution-engine",
        "fiber",
        "transport",
        "runtime",
        "future"
    ],
    "authors": [
        {
            "name": "BAGArt (Artur Baltaev)",
            "email": "baltaev.artur+ask@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "psr/container": "^2.0",
        "bagart/async-kernel": "*",
        "bagart/ask-client": "*",
        "bagart/daemon-runner": "*"
    },
    "autoload": {
        "psr-4": {
            "BAGArt\\TelegramBot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BAGArt\\TelegramBot\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@test:fullcycle",
            "@test:integration",
            "@test:offline",
            "@test:pest"
        ],
        "test:fullcycle": "php tests/Integration/FullCycleTest.php",
        "test:integration": "php tests/Integration/integration-test.php",
        "test:offline": "php tests/Integration/commands-offline-test.php",
        "test:pest": "@php ../../../vendor/bin/pest tests --colors=always"
    }
}
