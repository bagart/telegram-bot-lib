{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bagart/telegram-bot-lib",
    "type": "library",
    "description": "Telegram Bot core library",
    "keywords": ["telegram", "bot", "api"],
    "license": "MIT",
    "authors": [
        {
            "name": "BAGArt",
            "email": "baltaev.artur+lib@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "BAGArt\\TelegramBot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BAGArt\\TelegramBot\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@test:fullcycle",
            "@test:integration",
            "@test:offline",
            "@test:pest"
        ],
        "test:fullcycle": "php tests/Integration/FullCycleTest.php",
        "test:integration": "php tests/Integration/integration-test.php",
        "test:offline": "php tests/Integration/commands-offline-test.php",
        "test:pest": "@php ../../../vendor/bin/pest tests --colors=always"
    }
}
